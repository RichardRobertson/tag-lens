{
    "name": "tag-lens",
    "displayName": "Tag Lens",
    "description": "Visual Studio Code extension for locating and highlighting user defined tags",
    "version": "0.1.0",
    "publisher": "richard-robertson",
    "author": {
        "name": "Richard Robertson",
        "url": "https://github.com/RichardRobertson"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/RichardRobertson/tag-lens.git"
    },
    "bugs": {
        "url": "https://github.com/RichardRobertson/tag-lens/issues"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "license": "MIT",
    "activationEvents": [],
    "main": "./dist/extension.js",
    "l10n": "./l10n",
    "contributes": {
        "commands": [
            {
                "command": "tag-lens.rescanWorkspace",
                "title": "%tag-lens.commands.rescanWorkspace.title%",
                "icon": "$(refresh)"
            },
            {
                "command": "tag-lens.openGlobalConfig",
                "title": "%tag-lens.commands.openGlobalConfig.title%"
            },
            {
                "command": "tag-lens.openWorkspaceConfig",
                "title": "%tag-lens.commands.openWorkspaceConfig.title%"
            },
            {
                "command": "tag-lens.scanLanguageComments",
                "title": "%tag-lens.commands.scanLanguageComments.title%"
            }
        ],
        "configuration": {
            "title": "%tag-lens%",
            "properties": {
                "tag-lens.tags": {
                    "order": 0,
                    "title": "%tag-lens.configuration.tags.title%",
                    "markdownDescription": "%tag-lens.configuration.tags.markdownDescription%",
                    "type": "null",
                    "default": null
                },
                "tag-lens.styles": {
                    "order": 1,
                    "title": "%tag-lens.configuration.styles.title%",
                    "markdownDescription": "%tag-lens.configuration.styles.markdownDescription%",
                    "type": "null",
                    "default": null
                },
                "tag-lens.compactFolders": {
                    "order": 2,
                    "title": "%tag-lens.configuration.compactFolders.title%",
                    "markdownDescription": "%tag-lens.configuration.compactFolders.markdownDescription%",
                    "type": "string",
                    "enum": [
                        "editor",
                        "always",
                        "never"
                    ],
                    "markdownEnumDescriptions": [
                        "%tag-lens.configuration.compactFolders.editor.markdownDescription%",
                        "%tag-lens.configuration.compactFolders.always.markdownDescription%",
                        "%tag-lens.configuration.compactFolders.never.markdownDescription%"
                    ],
                    "default": "editor"
                },
                "tag-lens.search.workspace": {
                    "order": 3,
                    "title": "%tag-lens.configuration.search.workspace.title%",
                    "markdownDescription": "%tag-lens.configuration.search.workspace.markdownDescription%",
                    "type": "boolean",
                    "default": true
                },
                "tag-lens.search.external": {
                    "order": 4,
                    "title": "%tag-lens.configuration.search.external.title%",
                    "markdownDescription": "%tag-lens.configuration.search.external.markdownDescription%",
                    "type": "boolean",
                    "default": true
                }
            }
        },
        "jsonValidation": [
            {
                "fileMatch": "tag-lens.config.jsonc",
                "url": "./schema/tag-lens.config.json"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "tag-lens.rescanWorkspace",
                    "group": "navigation",
                    "when": "view == tag-lens.tree-view"
                }
            ]
        },
        "views": {
            "tag-lens-tree-container": [
                {
                    "id": "tag-lens.tree-view",
                    "name": "%tag-lens%",
                    "icon": "$(list-tree)"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "tag-lens-tree-container",
                    "title": "%tag-lens%",
                    "icon": "$(list-tree)"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.ts",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.ts --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.ts --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "biome check",
        "test": "vscode-test",
        "buildJsonSchema": "node buildJsonSchema.ts",
        "vscode-manifest-types": "vscode-manifest-types"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.110.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^6.0.3",
        "vscode-manifest-types": "github:RichardRobertson/vscode-manifest-types#v0.3.0"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1",
        "zod": "^4.4.3"
    }
}
