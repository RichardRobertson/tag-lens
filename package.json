{
    "name": "tag-lens",
    "displayName": "Tag Lens",
    "description": "Spiritual successor to Todo Tree by Gruntfuggly",
    "version": "0.1.0",
    "publisher": "Richard Robertson",
    "author": {
        "name": "Richard Robertson",
        "url": "https://github.com/RichardRobertson"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/RichardRobertson/tag-lens.git"
    },
    "bugs": {
        "url": "https://github.com/RichardRobertson/tag-lens/issues"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "tag-lens.helloWorld",
                "title": "Hello World"
            }
        ],
        "configuration": [],
        "views": {
            "tag-lens-tree-container": [
                {
                    "id": "tag-lens.tree-view",
                    "name": "%tag-lens.tree-view.name%",
                    "icon": "$(list-tree)"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "tag-lens-tree-container",
                    "title": "%tag-lens.tree-container.name%",
                    "icon": "$(list-tree)"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "biome check",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.110.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "vscode-manifest-types": "github:RichardRobertson/vscode-manifest-types#v0.2.0"
    }
}
